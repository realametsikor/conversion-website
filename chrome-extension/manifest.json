{
  "manifest_version": 3,
  "name": "ToolsNest – Quick Access to 100+ Free Tools",
  "short_name": "ToolsNest",
  "version": "1.0.0",
  "description": "Instantly access 100+ free online tools — compress images, convert PDFs, calculators, AI writing tools & more. All from your browser toolbar.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "ToolsNest – Quick Tools"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["contextMenus"],
  "homepage_url": "https://usetoolnest.com"
}
